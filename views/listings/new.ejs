<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>

<body>
    <h3>Create a new Listing</h3>
    <form method="post" action="/listings">

        <input type="text" name="listing[title]" placeholder="enter title">
        <br><br><br>
        <textarea name="listing[description]" placeholder="enter description"></textarea>
        <br><br><br>
        <input type="text" name="listing[image]" placeholder="enter image URL/Link">
        <br><br><br>
        <input type="number" name="listing[price]" placeholder="enter price">
        <br><br><br>
        <input type="text" name="listing[location]" placeholder="enter your location">
        <br><br><br>
        <input type="text" name="listing[country]" placeholder="enter your country">
        <br><br><br>
        <button>Add</button>

    </form>
</body>

</html>